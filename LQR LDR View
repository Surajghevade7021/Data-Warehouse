            NULL::integer AS conversion_count,
            NULL::integer AS arpa_amount,
            NULL::integer AS arft_amount,
            NULL::integer AS emandate_count,
            NULL::integer AS cash_flow_amount,
            NULL::integer AS cash_flow_count,
            NULL::text AS new_lead_count_date,
            NULL::timestamp with time zone AS refresh_date,
            'untouched'::text AS flag
           FROM ( SELECT abc.lead_id,
                    abc.contact_id,
                    abc.mobile_number,
                    abc.email_address,
                    abc.last_activity_created_at,
                    l.rm_id,
                    l.status_id,
                    l.substatus_id,
                    l.created_at,
                    ml3.name AS location,
                    mu.full_name,
                    mu.location_id,
                        CASE
                            WHEN l.status_id = 2 AND (l.substatus_id = ANY (ARRAY[5, 6, 57])) THEN 1
                            WHEN l.status_id = 1 AND (l.substatus_id = ANY (ARRAY[2, 3])) THEN 1
                            WHEN l.status_id = 4 AND l.substatus_id = 13 THEN 1
                            WHEN l.status_id = 5 AND (l.substatus_id = ANY (ARRAY[16, 18, 19, 21, 24, 25, 60])) THEN 1
                            ELSE NULL::integer
                        END AS workable_untouched,
                        CASE
                            WHEN l.status_id = 4 AND l.substatus_id = 14 THEN 1
                            WHEN l.status_id = 5 AND (l.substatus_id = ANY (ARRAY[55, 26])) THEN 1
                            WHEN l.status_id = 6 AND (l.substatus_id = ANY (ARRAY[35, 32, 53])) THEN 1
                            ELSE NULL::integer
                        END AS non_workable_unotuched
                   FROM lead l
                     RIGHT JOIN ( SELECT untouch.lead_id,
                            untouch.contact_id,
                            untouch.lead_type,
                            untouch.full_name,
                            untouch.first_name,
                            untouch.last_name,
                            untouch.mobile_number,
                            untouch.email_address,
                            untouch.last_activity_created_at,
                            untouch.rn
                           FROM ( SELECT unt.lead_id,
                                    unt.contact_id,
                                    unt.lead_type,
                                    unt.full_name,
                                    unt.first_name,
                                    unt.last_name,
                                    unt.mobile_number,
                                    unt.email_address,
                                    unt.last_activity_created_at,
                                    row_number() OVER (PARTITION BY unt.lead_id ORDER BY unt.last_activity_created_at DESC) AS rn
                                   FROM ( SELECT l_1.lead_id,
    c.contact_id,
    c.type AS lead_type,
  CASE
   WHEN c.full_name IS NULL THEN concat(c.first_name, ' ', c.last_name)::character varying
   ELSE c.full_name
  END AS full_name,
    c.first_name,
    c.last_name,
    c.mobile_number,
    c.email_address,
    aa.created_at AS last_activity_created_at
   FROM lead l_1
     JOIN ( SELECT a.lead_id,
      max(a.created_at) AS created_at
     FROM activity a
    WHERE a.activity_type_id = 1 AND lower(a.origin::text) = 'outbound'::text AND a.call_duration > 0::double precision OR a.activity_type_id = 4 OR a.activity_type_id = 2 AND (EXISTS ( SELECT 1
       FROM jsonb_array_elements(a.meta_info -> 'msgs'::text) elem(value)
      WHERE (elem.value ->> 'category'::text) = 'Outgoing'::text)) OR a.activity_type_id = 3 AND ((a.meta_info ->> 'status'::text) = ANY (ARRAY['Pending'::text, 'Sent'::text]))
    GROUP BY a.lead_id) aa ON l_1.lead_id = aa.lead_id
     JOIN contact c ON c.contact_id = l_1.contact_id
     JOIN contact_mapping cm ON c.contact_id = cm.contact_id AND l_1.rm_id = cm.rm_id
  WHERE c.is_active = true AND l_1.is_active = true AND cm.type = 'Sales'::mapping_type AND cm.end_date IS NULL AND aa.created_at < (now() - '30 days'::interval)) unt) untouch
                          WHERE untouch.rn = 1) abc ON abc.lead_id = l.lead_id
                     LEFT JOIN mst_user mu ON l.rm_id = mu.user_id
                     LEFT JOIN mst_location ml3 ON mu.location_id = ml3.location_id) preped
        UNION ALL
